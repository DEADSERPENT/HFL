# ============================================================
# .gitignore — HFL Research Project
# Samartha H V | MIT Bengaluru | 2026
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.ipynb_checkpoints/

# ── Java / Maven ─────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
.mvn/wrapper/maven-wrapper.jar

# ── NS-3 build artifacts ─────────────────────────────────────
SIMULATORS/ns3/ns-3-dev/build/
SIMULATORS/ns3/ns-3-dev/.lock-waf*
SIMULATORS/ns3/ns-3-dev/cmake-cache/
SIMULATORS/ns3/ns-3-dev/CMakeFiles/
SIMULATORS/ns3/ns-3-dev/CMakeCache.txt
SIMULATORS/ns3/ns-3-dev/.ninja*
SIMULATORS/ns3/ns-3-dev/*.cmake
SIMULATORS/ns3/ns-3-dev/compile_commands.json

# ── CloudSim Plus source (large, not our code) ───────────────
SIMULATORS/cloudsim-plus/cloudsim-plus-source/

# ── Virtual environment (5.9 GB — never commit) ──────────────
.venv/
venv/
env/
hfl_env/

# ── Raw datasets (2.6 GB — download via setup script) ────────
SIMULATORS/data/raw/

# ── Large processed arrays (re-generate with preprocess_healthcare.py) ──
# ecg_signals.npy  = 229 MB
SIMULATORS/data/processed/healthcare/ecg/ecg_signals.npy
# cxr_images.npy   = 1.7 GB
SIMULATORS/data/processed/healthcare/cxr/cxr_images.npy
# duplicate label file at wrong path
SIMULATORS/data/processed/healthcare/ecg_labels.npy

# NOTE: Small .npy files ARE tracked (partition indices, labels ≤100 KB):
#   data/processed/partitions/healthcare/device_0X_{train,val,test}.npy  (4-8 KB)
#   data/processed/healthcare/ecg/ecg_labels.npy   (40 KB)
#   data/processed/healthcare/cxr/cxr_labels.npy   (24 KB)
#   data/processed/healthcare/tabular/*.npy         (≤100 KB)
# These let any device reproduce exact splits without re-running partition step.

# ── Model checkpoints & exported models (large binaries) ─────
*.pt
*.pth
*.onnx
*.bin
*.h5
*.pkl
*.npz
checkpoints/
onnx/

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/
*.swp
*.swo
*~

# ── OS artifacts ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ──────────────────────────────────────────────────
*.ipynb
!notebooks/**/*.ipynb

# ── Logs & temp ──────────────────────────────────────────────
*.tmp
*.bak
*.orig
/tmp/

# ── RESUME tmp (keep locally, not in repo) ───────────────────
RESUME/

# ── Sensitive config (never commit credentials) ──────────────
.env
secrets.json
credentials.json

# ── Dashboard build artifacts ────────────────────────────────
flvision-dashboard/node_modules/
flvision-dashboard/dist/
flvision-dashboard/.vite/
flvision-dashboard/*.local
hfl-dashboard/node_modules/
hfl-dashboard/dist/
hfl-dashboard/.vite/
hfl-dashboard/*.local
